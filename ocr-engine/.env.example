# ══════════════════════════════════════════════════════════════════════════
# OCR Engine — Environment Configuration
# Service này chứa toàn bộ ML logic: PaddleOCR + HuggingFace Correction
# ══════════════════════════════════════════════════════════════════════════
# Copy: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# ── App Settings ─────────────────────────────────────────────────────────
APP_NAME="OCR AI Engine"

# Port:
#   - Local dev / Docker Compose : 8002
#   - SageMaker                  : 8080 (BẮT BUỘC, SageMaker chỉ mở port này)
API_PORT=8002

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── ML Model ─────────────────────────────────────────────────────────────
# Chạy local: tải từ HuggingFace Hub
CORRECT_MODEL_ID=protonx-models/protonx-legal-tc
# Chạy SageMaker (VPC không có internet): trỏ vào S3 artifact đã extract
# CORRECT_MODEL_ID=/opt/ml/model/model_weights

# Thư mục cache HuggingFace — mount Docker volume để tránh tải lại mỗi lần
# Để trống = dùng ~/.cache/huggingface mặc định
# MODEL_CACHE_DIR=/app/hf_cache

# ── OCR Image Processing ──────────────────────────────────────────────────
# Kích thước ảnh tối đa trước khi OCR (px). Tăng = chính xác hơn, chậm hơn.
#   - CPU  : 1024 (đủ nhanh)
#   - GPU  : 1600 (khuyến nghị)
#   - GPU+  : 2048 (chất lượng cao nhất, cần VRAM >= 16GB)
OCR_IMAGE_SIZE=1600

# DPI render PDF → ảnh. Tăng = rõ nét hơn, tốn RAM hơn.
#   - Tài liệu đơn giản : 150
#   - Tài liệu thông thường: 200 (khuyến nghị)
#   - Tài liệu nhỏ/chữ mờ : 300
OCR_DPI=200

# ── Process Limits ────────────────────────────────────────────────────────
MAX_PDF_PAGES=100
MAX_FILE_SIZE_MB=50

# ── Concurrency ───────────────────────────────────────────────────────────
# Để trống → hệ thống tự detect:
#   - GPU (CUDA) : 2 luồng (giới hạn để tránh OOM VRAM)
#   - CPU / MPS  : CPU count
# MAX_WORKERS=4
