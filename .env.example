# ══════════════════════════════════════════════════════════════════════════
# OCR SageMaker Service — Environment Configuration
# Kiến trúc Option A: Service này là proxy nhẹ, gọi về LiteLLM Gateway
# của AI Hub để thực hiện OCR inference. Mọi token đều đi qua FinOps.
# ══════════════════════════════════════════════════════════════════════════
# Copy: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# ── App Settings ────────────────────────────────────────────────────────
APP_NAME="OCR SageMaker Service"

# Port:
#   - Local dev : 8001
#   - SageMaker : 8080 (SageMaker yêu cầu cố định)
API_PORT=8001

# ── LiteLLM Gateway (AI Hub) ────────────────────────────────────────────
# Đây là 2 biến quan trọng nhất — OCR service gọi về Gateway để inference.
#
# Local dev: Gateway chạy trong docker compose của AI Hub
GATEWAY_URL=http://localhost:4000
# SageMaker production: đổi sang URL public/internal của AI Hub Gateway
# GATEWAY_URL=https://gateway.your-domain.com
# GATEWAY_URL=http://<alb-or-nlb-dns>:4000   # nếu cùng VPC

LITELLM_MASTER_KEY=sk-aihub-gateway-master

# ── Process Limits ───────────────────────────────────────────────────────
MAX_PDF_PAGES=100
MAX_FILE_SIZE_MB=50

# ── Concurrency ──────────────────────────────────────────────────────────
# Bỏ comment để ghi đè auto-detect (CPU count):
# MAX_WORKERS=4
