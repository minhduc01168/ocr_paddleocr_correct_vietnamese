# ══════════════════════════════════════════════════════════════════════════
# OCR Orchestrator Service — Environment Configuration
# Kiến trúc: Service này nhận request và chuyển tiếp về OCR Engine
# ══════════════════════════════════════════════════════════════════════════
# Copy: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# ── App Settings ─────────────────────────────────────────────────────────
APP_NAME="OCR Orchestrator Service"

# Port:
#   - Local dev : 8001
#   - SageMaker : 8080 (SageMaker yêu cầu cố định)
API_PORT=8001

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Số Uvicorn workers (tăng cho production)
# WORKERS=2

# ── OCR Engine URL ────────────────────────────────────────────────────────
# Local dev (chạy thẳng không Docker): http://localhost:8002
# Docker Compose: http://ocr-engine:8002
OCR_ENGINE_URL=http://localhost:8002

# ── LiteLLM Gateway (AI Hub) ─────────────────────────────────────────────
# Local dev: Gateway chạy trong docker compose của AI Hub
GATEWAY_URL=http://localhost:4000
# SageMaker production: đổi sang URL public/internal của AI Hub Gateway
# GATEWAY_URL=https://gateway.your-domain.com

GATEWAY_KEY=sk-aihub-gateway-master

# ── Process Limits ────────────────────────────────────────────────────────
MAX_PDF_PAGES=100
MAX_FILE_SIZE_MB=50
