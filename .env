# Tên ứng dụng
APP_NAME="Enhanced Local OCR & SageMaker Service"

# Cổng khởi động (SageMaker mặc định lắng nghe ở 8001)
API_PORT=8001

# Số trang tối đa cho 1 file PDF
MAX_PDF_PAGES=100

# Dung lượng Tối đa cho việc Tải URL (MB)
MAX_FILE_SIZE_MB=50

# HuggingFace Correction Model ID
CORRECT_MODEL_ID="protonx-models/protonx-legal-tc"

# Tính toán Đa luồng: 
# Không đặt, Hệ thống Tự chọn: CPU count (cho CPU/MPS), hoặc 2 (cho GPU)
# MAX_WORKERS=4
